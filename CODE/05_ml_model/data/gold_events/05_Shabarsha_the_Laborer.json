 "class": "I_STATE", "tense": "PAST", "aspect": "NONE"}, {"id": "1837", "off": 2817, "word": "to wrestle", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "1838", "off": 2844, "word": "cracked", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "1840", "off": 2901, "word": "had started", "class": "ASPECTUAL", "tense": "PAST", "aspect": "PERFECT"}, {"id": "1841", "off": 2913, "word": "to wrestle", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "3735", "off": 2937, "word": "\"Hmm, go and try to have a foot race with Shabarsha; we'll see who can win \nthat.\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1842", "off": 2943, "word": "go", "class": "OCCURRENCE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "1843", "off": 2950, "word": "try", "class": "I_ACTION", "tense": "PRESENT", "aspect": "NONE"}, {"id": "1844", "off": 2954, "word": "to have a foot race", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "1846", "off": 2992, "word": "'ll see", "class": "OCCURRENCE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "1847", "off": 3004, "word": "can win", "class": "OCCURRENCE", "tense": "NONE", "aspect": "NONE"}, {"id": "1848", "off": 3057, "word": "came", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "1849", "off": 3082, "word": "repeated", "class": "REPORTING", "tense": "PAST", "aspect": "NONE"}, {"id": "1850", "off": 3130, "word": "replied", "class": "REPORTING", "tense": "PAST", "aspect": "NONE"}, {"id": "1851", "off": 3144, "word": "should I race", "class": "OCCURRENCE", "tense": "NONE", "aspect": "NONE"}, {"id": "1852", "off": 3208, "word": "will leave you far behind", "class": "OCCURRENCE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "3736", "off": 3237, "word": "\"And where is your little brother Bunny?\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1853", "off": 3242, "word": "where is", "class": "STATE", "tense":