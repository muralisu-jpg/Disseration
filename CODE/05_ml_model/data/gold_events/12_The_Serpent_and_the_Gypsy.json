"id": "1767", "off": 1149, "word": "said", "class": "REPORTING", "tense": "PAST", "aspect": "NONE"}, {"id": "1768", "off": 1181, "word": "turned a profit", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "1769", "off": 1202, "word": "left", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "3854", "off": 1231, "word": "have", "class": "STATE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "3855", "off": 1247, "word": "'ll have", "class": "STATE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "1770", "off": 1303, "word": "think", "class": "I_STATE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "1771", "off": 1313, "word": "can eat", "class": "OCCURRENCE", "tense": "NONE", "aspect": "NONE"}, {"id": "1772", "off": 1326, "word": "asked", "class": "REPORTING", "tense": "PAST", "aspect": "NONE"}, {"id": "1773", "off": 1345, "word": "\"Yes, indeed, I will eat you.\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1774", "off": 1361, "word": "will eat", "class": "OCCURRENCE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "1775", "off": 1378, "word": "\"You lie, devilish fiend.  You will choke!\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1776", "off": 1383, "word": "lie", "class": "OCCURRENCE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "1777", "off": 1409, "word": "will choke", "class": "OCCURRENCE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "1778", "off": 1423, "word": "\"So then, you think you are stronger than me?\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1779", "off": 1437, "word": "think", "class": "I_STATE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "1780", "off": 1471, "word": "\"I should say so!  I think even you realize I have greater strength than you.\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "1781", "off": 1474, "word": "should say", "class": "OCCURRENCE", "tense": "NONE", "aspect": "NONE"}, {"id": "1782", "off": 1492, "