": "'ve never been able", "class": "STATE", "tense": "PRESENT", "aspect": "PERFECT"}, {"id": "2515", "off": 1513, "word": "to read", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "2516", "off": 1513, "word": "to read or write", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "2517", "off": 1533, "word": "didn't know", "class": "STATE", "tense": "PAST", "aspect": "NONE"}, {"id": "2518", "off": 1567, "word": "'s too late", "class": "STATE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "2519", "off": 1579, "word": "to learn", "class": "OCCURRENCE", "tense": "INFINITIVE", "aspect": "NONE"}, {"id": "4930", "off": 1591, "word": "\"Never mind, soldier, this is the sort of book that whoever looks at it will \nbe able to read.\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "2520", "off": 1592, "word": "Never mind", "class": "OCCURRENCE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "4931", "off": 1688, "word": "\"Alright, give it to me and I'll try.\"", "class": "REPORTING", "tense": "NONE", "aspect": "NONE"}, {"id": "2521", "off": 1698, "word": "give", "class": "OCCURRENCE", "tense": "PRESENT", "aspect": "NONE"}, {"id": "2522", "off": 1717, "word": "'ll try", "class": "OCCURRENCE", "tense": "FUTURE", "aspect": "NONE"}, {"id": "2523", "off": 1740, "word": "opened up", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "2524", "off": 1763, "word": "started", "class": "ASPECTUAL", "tense": "PAST", "aspect": "NONE"}, {"id": "2525", "off": 1771, "word": "reading", "class": "OCCURRENCE", "tense": "PRESPART", "aspect": "NONE"}, {"id": "2526", "off": 1832, "word": "was delighted", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "2527", "off": 1862, "word": "handed over", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "2528", "off": 1903, "word": "took", "class": "OCCURRENCE", "tense": "PAST", "aspect": "NONE"}, {"id": "2529", "off": 1915, "word": "began", "c